# ── Patogh — Production Environment Variables ─────────────────────────────────
#
# Copy this file to .env and fill in all required values before running
# docker-compose up in production.
#
# NEVER commit .env to version control.
# .env is intentionally listed in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password. Generate: openssl rand -base64 32
POSTGRES_PASSWORD=20042040

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=20042040

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED. At least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=20042040

# ── SMS Provider (optional) ───────────────────────────────────────────────────
# If left empty, ConsoleSmsSender is used (logs to stdout — NOT suitable for production).
# Add provider credentials here and wire them up in DependencyInjection.cs.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
